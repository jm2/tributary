# The English locale is historically CRLF. Keep Git's whitespace checker
# strict while treating the carriage return at its line ending as intentional.
locales/en.yml whitespace=cr-at-eol

# The vendored Flatpak generator is verified byte-for-byte at build time.
build-aux/flatpak/flatpak-cargo-generator.py text eol=lf
build-aux/flatpak/*.sh text eol=lf
build-aux/flatpak/*.sha256 text eol=lf
